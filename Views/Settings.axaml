<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HaveItMain.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="600"
             x:Class="HaveItMain.Views.SettingsView"
             x:DataType="viewModels:Settings">
    <UserControl.Styles>
        <Style Selector="ToggleButton.toggle-btn">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Root"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Panel HorizontalAlignment="Stretch"
                               VerticalAlignment="Center">
                            <TextBlock x:Name="EnabledText"
                                       Text="Enabled"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrushBackground}"
                                       IsVisible="False"/>
                            <TextBlock x:Name="DisabledText"
                                       Text="Disabled"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrushPrimary}"
                                       IsVisible="True"/>
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.toggle-btn:checked /template/ TextBlock#EnabledText">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="ToggleButton.toggle-btn:checked /template/ TextBlock#DisabledText">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <!--
        <Style Selector="Button.action-btn">
            <Setter Property="Width"       Value="46"/>
            <Setter Property="Height"      Value="34"/>
            <Setter Property="Background"  Value="#FFCC00"/>
            <Setter Property="Foreground"  Value="#FFFFFF"/>
            <Setter Property="FontSize"    Value="20"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Padding"     Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Effect">
                <DropShadowEffect Color="Black"
                                  BlurRadius="6"
                                  OffsetX="0"
                                  OffsetY="2"
                                  Opacity="0.25"/>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="#FFFFFF"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        -->
        
        <Style Selector="ToggleButton.toggle-btn:checked /template/ TextBlock#EnabledText">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="ToggleButton.toggle-btn:checked /template/ TextBlock#DisabledText">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Slider.yellow-slider">
            <Setter Property="Height" Value="35"/>
        </Style>

        <Style Selector="Slider.yellow-slider /template/ Border#SliderContainer">
            <Setter Property="BorderBrush"     Value="{StaticResource BrushPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
        </Style>

        <Style Selector="Slider.yellow-slider /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
        </Style>
        <Style Selector="Slider.yellow-slider /template/ RepeatButton#PART_DecreaseButton /template/ Border">
            <Setter Property="Background"   Value="{StaticResource BrushPrimary}"/>
            <Setter Property="CornerRadius" Value="8,0,0,8"/>
            <Setter Property="Height"       Value="8"/>
        </Style>

        <Style Selector="Slider.yellow-slider /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Background" Value="#FCFCFC"/>
        </Style>
        <Style Selector="Slider.yellow-slider /template/ RepeatButton#PART_IncreaseButton /template/ Border">
            <Setter Property="Background"   Value="#FCFCFC"/>
            <Setter Property="CornerRadius" Value="0,8,8,0"/>
            <Setter Property="Height"       Value="8"/>
        </Style>

        <Style Selector="Slider.yellow-slider /template/ Thumb">
            <Setter Property="Width"      Value="18"/>
            <Setter Property="Height"     Value="18"/>
            <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
        </Style>
        <Style Selector="Slider.yellow-slider /template/ Thumb /template/ Ellipse">
            <Setter Property="Fill"            Value="{StaticResource BrushPrimary}"/>
            <Setter Property="Stroke"          Value="#E0AA00"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="ComboBox /template/ Border#Background">
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="#FFF5CC"/>
        </Style>

        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Foreground" Value="#000000"/>
        </Style>

        <Style Selector="TextBlock.setting-label">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24"
                    Spacing="0"
                    HorizontalAlignment="Stretch">
            <Grid Margin="24"
                  ColumnDefinitions="*, Auto, 120,*"
                  ColumnSpacing="20"
                  RowSpacing="30"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- Row 0 – Font Size -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Adjust Text Size (Ctrl + - / Ctrl + =)"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          Width="80"
                          x:Name="FontSizePicker" 
                          SelectedIndex="1"
                          >
                    <ComboBoxItem Content="12"/>
                    <ComboBoxItem Content="14"/>
                    <ComboBoxItem Content="16"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="24"/>
                </ComboBox>

                <Grid Grid.Row="0"
                      Grid.Column="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="6">

                    <Button Grid.Column="0"
                            Content="-"
                            Click="DecreaseFont"
                            Classes="Primary"
                            HorizontalAlignment="Left"/>

                    <Button Grid.Column="1"
                            Content="+"
                            Classes="Primary"
                            Click="IncreaseFont"
                            HorizontalAlignment="Right"/>
                </Grid>
                
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Dyslexic Mode"
                           VerticalAlignment="Center"/>

                <ToggleButton Grid.Row="1"
                              Grid.Column="2"
                              Classes="Primary toggle-btn"
                              HorizontalAlignment="Stretch"/>
                <!-- 
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="High Contrast Mode"
                           VerticalAlignment="Center"/>

                <ToggleButton Grid.Row="2"
                              Grid.Column="2"
                              Classes="Primary toggle-btn"
                              HorizontalAlignment="Stretch"/>
                                              -->
                <TextBlock Grid.Column="0" Grid.Row="2" Classes="setting-label" Text="Enable Tactile SFX"/>
                <ToggleButton Grid.Row="2"
                              Grid.Column="2"
                              Classes="Primary toggle-btn"
                              IsChecked="{Binding State.EnableSfx, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>
                <TextBlock Grid.Column="0" Grid.Row="3" Classes="setting-label" Text="SFX Volume"/>
                <Slider Grid.Column="2" Grid.Row="3" Classes="yellow-slider" Width="100" Minimum="0" Maximum="100" Value="60" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="0" Grid.Row="4" Classes="setting-label" Text="Enable Notification Ping"/>
                <ToggleButton Grid.Row="4"
                              Grid.Column="2"
                              IsChecked="{Binding State.NotificationsGlobal, Mode=TwoWay}"
                              Classes="Primary toggle-btn"
                              HorizontalAlignment="Stretch"/>
                
            </Grid>
        </StackPanel>
    </ScrollViewer>

</UserControl>
