<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HaveItMain.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"    
        xmlns:views="clr-namespace:HaveItMain.Views"
        Width="1280"
        Height="720"
        MinHeight="621"
        MinWidth="1104"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}"
        d:DesignWidth="1280"
        d:DesignHeight="720"
        x:Class="HaveItMain.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://HaveItMain/Assets/Icon-ForDocker.png"
        Title="Have-It">
    
    <Grid x:Name="Windowgrid" ColumnDefinitions="72,87,* ,30" Background="{StaticResource BrushBackground}">
        <Border 
            x:Name="LEFTMENUBAR"
            Grid.Column="0"
            Background="{StaticResource ColorPrimary}"
            ZIndex="1"
            DoubleTapped="LEFTMENUBAR_OnDoubleTapped"> <!-- extra space on the right -->
            
            <Border.Effect>
                <DropShadowEffect 
                    Color="Black" 
                    BlurRadius="8" 
                    OffsetX="3"
                    OffsetY="0"
                    Opacity="0.25"/>
            </Border.Effect>
            <Grid x:Name="LeftMenuContent" RowDefinitions="72,*,73">
                <Border Grid.Row="0">
                    <Border PointerPressed="InputElement_OnPointerPressed" Cursor="Hand" ToolTip.Tip="Dashboard (D)">
                            <Image Source="avares://HaveItMain/Assets/INVERTED LOGO.png"
                                   Width="50"
                                   Height="50"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Stretch="Uniform"/>
                    </Border>
                </Border> <!-- LOGO -->
                <Border Grid.Row="1">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
                        <Button ToolTip.Tip="Streak (S)" Classes="round-button" Click="Streak_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="Black" 
                                                  BlurRadius="4" 
                                                  OffsetX="-3"
                                                  OffsetY="3"
                                                  Opacity="0.25"/>
                            </Button.Effect>
                            <Image Source="avares://HaveItMain/Assets/smenu.png"
                                   Margin="5"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Button>
                        <Button ToolTip.Tip="Timer (T)" Classes="round-button" Click="Timer_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="Black" 
                                                  BlurRadius="4" 
                                                  OffsetX="-3"
                                                  OffsetY="3"
                                                  Opacity="0.25"/>
                            </Button.Effect>
                            <Image Source="avares://HaveItMain/Assets/tmenu.png"
                                   Margin="7"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Button>
                        <Button ToolTip.Tip="Settings (Ctrl + S)" Classes="round-button" Click="Settings_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="Black" 
                                                  BlurRadius="4" 
                                                  OffsetX="-3"
                                                  OffsetY="3"
                                                  Opacity="0.25"/>
                            </Button.Effect>
                            <Image Source="avares://HaveItMain/Assets/setmenu.png"
                                   Margin="4"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border> <!-- 3 Buttons -->
                <Border Grid.Row="2">
                    <Button Classes="round-button" VerticalAlignment="Top" ToolTip.Tip="New Routine (Ctrl + N)" Click="NEW_ROUTINE">
                        <Button.Effect>
                            <DropShadowEffect Color="Black" 
                                              BlurRadius="4" 
                                              OffsetX="-3"
                                              OffsetY="3"
                                              Opacity="0.25"/>
                        </Button.Effect>
                        <Image Source="avares://HaveItMain/Assets/WriteMenu.png"
                               Margin="9"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Button>
                </Border> <!-- NEW ROUTINE -->
            </Grid>
        </Border> <!-- LEFT BORDER-->
        <Border Grid.Column="2" Background="{StaticResource ColorBackground}" ZIndex="0"> <!-- RIGHT BORDER MAIN CONTENT-->
            <Grid RowDefinitions="105, *">
                <Border Grid.Row="0" Margin="0,35,0,0" BorderThickness="0,0,0,2" BorderBrush="{StaticResource BrushForeground}" Padding="0,0,0,16">
                    <Grid ColumnDefinitions="240, Auto, *, 300, 60">
                        <Border Grid.Column="0" >
                            <TextBlock
                                Text="{Binding CurrentTitle}"
                                Classes="Headers" 
                                FontSize="36" 
                                FontWeight="Bold" 
                                HorizontalAlignment="Left" 
                                VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1">
                            <!-- SEARCH CONTAINER -->
                            <!--
                            <Border CornerRadius="10"
                                    Background="#F0F0F0"
                                    Padding="4"
                                    Margin="10,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center">

                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="🔍 "
                                               FontSize="13"
                                               Margin="13,0,20,0"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Watermark="Search..."
                                             BorderThickness="0"
                                             Background="Transparent"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"/>
                                </Grid>
                            </Border>
                            -->
                        </Border>
                        <Border Grid.Column="2"></Border>
                        <Border Grid.Column="3">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <StackPanel Orientation="Vertical" Margin="0,0,20,0" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Right" TextAlignment="Right" PointerPressed="AccountSettings_Click" Cursor="Hand"> Username Test </TextBlock>
                                    <TextBlock HorizontalAlignment="Right" TextAlignment="Right" PointerPressed="AccountSettings_Click" Cursor="Hand"> Pricing Plan </TextBlock>
                                </StackPanel> 
                                <!--<Border
                                    PointerPressed="AccountSettings_Click"
                                    Margin="0,0,10,0" 
                                    CornerRadius="100" 
                                    Background="Gray" 
                                    Width="48" 
                                    Height="48"/> -->
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Padding="0,0, 0,0">
                            <Button Classes="null_for_image" Click="ComboBoxClick">
                                <Button.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Account Settings" PointerPressed="AccountSettings_Click"/>
                                        <MenuItem Header="Log Out"/>
                                        <MenuItem Header="Export"/>
                                        <MenuItem Header="Import"/>
                                        <MenuItem Header="Demo Video" Click="Demo_VideoClick"/>
                                        <MenuItem Header="About" Click="Landing"/>
                                    </MenuFlyout>
                                </Button.ContextFlyout>
                                <Image Source="avares://HaveItMain/Assets/SANDWHICHbutton.png"
                                       Width="35"
                                       Height="35"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                />
                            </Button>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1"> <!-- DYNAMIC CONTENTS IS LOCATED HERE -->
                    <Border Margin="0,20,0,20">
                        <ContentControl Content="{Binding CurrentViewModel}">
                            <ContentControl.DataTemplates>
                                <!-- Dashboard -->
                                <DataTemplate DataType="vm:Dashboard">
                                    <views:DashboardView /> <!-- automatically gets DataContext -->
                                </DataTemplate>

                                <!-- Timer -->
                                <DataTemplate DataType="vm:Timer">
                                    <views:TimerView /> <!-- automatically gets DataContext -->
                                </DataTemplate>
                            </ContentControl.DataTemplates>
                        </ContentControl>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>

</Window>
