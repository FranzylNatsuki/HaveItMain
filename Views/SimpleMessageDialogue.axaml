<views:BaseDialog
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:HaveItMain.Views"
    x:Class="HaveItMain.Views.SimpleMessageDialog">
    <Border BorderBrush="{StaticResource BrushPrimary} " BorderThickness="2" CornerRadius="11">
        <StackPanel Spacing="12" >
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       FontSize="18"
                       HorizontalAlignment="Center"/>
            <Button Content="OK"
                    HorizontalAlignment="Center"
                    Click="Ok_Click"/>
        </StackPanel>
    </Border>
</views:BaseDialog>