<views:BaseDialog
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:HaveItMain.Views"
    x:Class="HaveItMain.Views.SimpleMessageDialog"
    SystemDecorations="None">
    <Border BorderBrush="{StaticResource BrushPrimary}" Background="{StaticResource BrushBackground}" BorderThickness="2" CornerRadius="11">
        <Grid RowDefinitions="*,*" Margin="20">
            <TextBlock x:Name="MessageText"
                       Grid.Row="0"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="UltraBold"/>
            <Button Grid.Row="1" Content="Okay"
                    Classes="Primary"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="Ok_Click"/>
        </Grid>
    </Border>
</views:BaseDialog>