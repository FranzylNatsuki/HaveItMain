<views:BaseDialog
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:HaveItMain.Views"
    x:Class="HaveItMain.Views.ConfirmationDialog"
    SystemDecorations="None"
    Width="450"
    Height="270">
    <Border BorderBrush="{StaticResource BrushPrimary}" Background="{StaticResource BrushBackground}" BorderThickness="2" CornerRadius="5">
        <Grid RowDefinitions="*,*" Margin="30">
            <TextBlock x:Name="MessageText"
                       Grid.Row="0"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="UltraBold"/>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="20">
                <Button Content="Proceed"
                        Classes="Primary"
                        Click="Confirm_Click"/>
                <Button Content="Cancel"
                        Classes="Universal_Button"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</views:BaseDialog>