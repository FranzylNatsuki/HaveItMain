<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaveItMain.ViewModels"
             xmlns:views="using:HaveItMain.Views"
             x:Class="HaveItMain.App"
             xmlns:local="using:HaveItMain"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             <Application.DataTemplates>
                 <DataTemplate DataType="vm:Dashboard">
                     <views:DashboardView/>
                 </DataTemplate>
                 <DataTemplate DataType="vm:AccountSettings">
                     <views:AccountSettingsView/>
                 </DataTemplate>
                 <DataTemplate DataType="vm:Timer">
                     <views:TimerView/>
                 </DataTemplate>
                 <DataTemplate DataType="vm:Settings">
                     <views:SettingsView/>
                 </DataTemplate>
                 <DataTemplate DataType="vm:Streak">
                     <views:StreakView/>
                 </DataTemplate>
             </Application.DataTemplates>
             <Application.Resources>
                 <!-- Colors -->
                 <Color x:Key="ColorPrimary">#FFAA00</Color>
                 <Color x:Key="ColorSecondary">#FF8000</Color>
                 <Color x:Key="Complement"> #00B2FF </Color>
                 <Color x:Key="ColorBackground">#FFFFFFFF</Color>
                 <Color x:Key="ColorForeground">#FF000000</Color>

                 <!-- Brushes (what UI actually uses) -->
                 <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="BrushSecondary" Color="{StaticResource ColorSecondary}"/>
                 <SolidColorBrush x:Key="BrushCompliment" Color="{StaticResource Complement}"/>
                 <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}"/>
                 <SolidColorBrush x:Key="BrushForeground" Color="{StaticResource ColorForeground}"/>
                 
                 <!-- Track -->
                 <SolidColorBrush x:Key="SliderTrackValueFill" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderTrackFill" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderTrackFillPressed" Color="{StaticResource ColorPrimary}"/>

                 <!-- Thumb -->
                 <SolidColorBrush x:Key="SliderThumbBackground" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="{StaticResource ColorPrimary}"/>
                 <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="{StaticResource ColorPrimary}"/>
                 <!-- etc... -->
             </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="20,7,20,7"></Setter>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style Selector="Button.Universal_Button">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="20,7,20,7"></Setter>
        </Style>
        <Style Selector="Button.Primary">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Background" Value="#FFAA00"></Setter>
            <Setter Property="Padding" Value="20,7,20,7"></Setter>
        </Style>
        <Style Selector="ToggleButton.Primary">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Background" Value="#FFAA00"></Setter>
            <Setter Property="Padding" Value="20,7,20,7"></Setter>
        </Style>
        <Style Selector="Button.Closing">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="Foreground" Value="Black"></Setter>
            <Setter Property="BorderThickness" Value="1"></Setter>
            <Setter Property="BorderBrush" Value="Black"></Setter>
            <Setter Property="Padding" Value="20,7,20,7"></Setter>
            <Setter Property="Background" Value="White"></Setter>
        </Style>
        <Style Selector="ToggleButton.Closing">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="Foreground" Value="Black"></Setter>
            <Setter Property="BorderThickness" Value="1"></Setter>
            <Setter Property="BorderBrush" Value="Black"></Setter>
            <Setter Property="Padding" Value="20,7,20,7"></Setter>
            <Setter Property="Background" Value="White"></Setter>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
        
        <Style Selector="TextBlock.Headers">
            <Setter Property="FontSize" Value="45"></Setter>
            <Setter Property="FontWeight" Value="ExtraBold"/>
        </Style>

        <!-- Button -->
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="CornerRadius" Value="8"></Setter>
        </Style>

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="FontFamily" Value="avares://HaveItMain/Assets/Nunito-VariableFont_wght.ttf#Nunito"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
                    <Style Selector="Button.null_for_image">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style Selector="Button.null_for_image:pointerover">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="Button.null_for_image:pressed">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
            </Style>
        <Style Selector="Button.round-button">
            <!-- remove default padding and border -->
            <Setter Property="Background" Value="{StaticResource ColorBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" 
                                      BlurRadius="4" 
                                      OffsetX="-3"
                                      OffsetY="3"
                                      Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Hover -->
        <Style Selector="Button.round-button:pointerover">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Press -->
        <Style Selector="Button.round-button:pressed">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.90" ScaleY="0.90"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#D0D0D0"/>
        </Style>
    </Application.Styles>
</Application>